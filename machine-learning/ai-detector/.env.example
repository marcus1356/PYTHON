# Application
APP_NAME="AI Detector"
DEBUG=false
API_V1_PREFIX=/api/v1
APP_PORT=8002

# Database
DATABASE_URL=sqlite+aiosqlite:///./ai_detector.db

# Claude API (Anthropic) — obtenha em https://console.anthropic.com
# Deixe vazio para desabilitar o fallback para Claude
ANTHROPIC_API_KEY=

# Limiar de confiança ML para acionar Claude (zona incerta)
CLAUDE_CONFIDENCE_THRESHOLD=0.15

# Exemplos novos necessários para disparar retrain do Random Forest
RETRAIN_THRESHOLD=50
